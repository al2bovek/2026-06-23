PORT=3000
NODE_ENV=development

PG_USER=dubovek
PG_PASSWORD=user_password
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=postgres

# DATABASE_URL=postgresql://postgres:password@localhost:5432/database

# Protocol — postgresql:// tells your app to use the PostgreSQL driver
# User — dubovek is the database username
# Password — user_password is the user’s password
# Host — localhost means the DB is running on your machine
# Port — 5432 is the default PostgreSQL port
# Database — postgres is the database your app will connect to

DATABASE_URL=postgresql://dubovek:user_password@localhost:5432/postgres

PREFIX=/api/v1

JWT_SECRET=jwt_secret_key
CLIENT_ORIGIN=http://localhost:5173
